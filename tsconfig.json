{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["src/ui/*"],
      "@service/*": ["src/service/*"],
    }
  }
}
